# =====================================================
# .gitignore raíz — Proyecto PetBox (monorepo Spring Boot)
# =====================================================

# --- Maven ---
**/target/
!**/src/main/**/target/
!**/src/test/**/target/
**/.mvn/wrapper/maven-wrapper.jar
**/dependency-reduced-pom.xml
**/release.properties
**/pom.xml.tag
**/pom.xml.releaseBackup
**/pom.xml.versionsBackup
**/pom.xml.next
**/buildNumber.properties

# --- Java / compilados ---
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# --- Eclipse / STS ---
.classpath
.project
.settings/
.springBeans
.sts4-cache/
.apt_generated/
.factorypath

# --- IntelliJ IDEA ---
.idea/
*.iws
*.iml
*.ipr
out/

# --- NetBeans ---
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# --- VS Code ---
.vscode/

# --- Logs / sistema ---
*.log
logs/
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Spring Initializr / docs autogenerados ---
**/HELP.md

# --- Secretos / configuración local ---
**/application-local.properties
**/application-secret.properties
**/.env
**/.env.local

# --- Herramientas internas de modernización (no se sube) ---
.github/modernize/
**/.github/modernize/
